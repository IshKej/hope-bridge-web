# Supabase project config (get these from your Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: Never put your service_role key in this file or commit it anywhere.
# It bypasses Row Level Security and should only be used in secure server environments.
